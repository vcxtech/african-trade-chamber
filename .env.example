# Copy to .env for local development
# Use port 5433 — Docker maps host 5433 → container 5432 (avoids Windows Postgres on 5432)
DATABASE_URI=postgresql://atc:atc_secret@localhost:5433/atc_website
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Admin login requires the browser URL to match these exactly (use localhost, not 192.168.x.x)
NEXT_PUBLIC_SERVER_URL=http://localhost:3002
PAYLOAD_SERVER_URL=http://localhost:3002
PAYLOAD_COOKIE_SECURE=false

# After schema is stable locally, set false to skip Drizzle push on every dev request
# (stops long "Pulling schema from database..." spam in the terminal)
# PAYLOAD_DB_PUSH=false

# Coolify / production (set in Coolify UI — never commit real secrets)
# DATABASE_URI=postgresql://atc:YOUR_PASSWORD@atc-postgres:5432/atc_website
# NEXT_PUBLIC_SERVER_URL=http://your-app.sslip.io
# PAYLOAD_SERVER_URL=http://your-app.sslip.io
# AUTO_SEED=true
# SEED_ADMIN_EMAIL=admin@africantradechamber.org
# SEED_ADMIN_PASSWORD=choose-a-strong-password

# Optional: recipient for country office "Request Our Services" form (mailto)
# NEXT_PUBLIC_SERVICE_REQUEST_EMAIL=info@africantradechamber.org

# SMTP — form submission email notifications (set in Coolify for production)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_ADDRESS=noreply@africantradechamber.org
# SMTP_FROM_NAME=African Trade Chamber
# FORM_DEFAULT_NOTIFY_EMAIL=info@africantradechamber.org

# Per-form notification overrides (optional)
# NEXT_PUBLIC_MEMBERSHIP_NOTIFY_EMAIL=info@africantradechamber.org
# NEXT_PUBLIC_FELLOWSHIP_NOTIFY_EMAIL=info@africantradechamber.org
# NEXT_PUBLIC_CAREERS_NOTIFY_EMAIL=info@africantradechamber.org
# NEXT_PUBLIC_SME_COUNCIL_NOTIFY_EMAIL=info@africantradechamber.org

# First admin user (created by seed when no users exist)
SEED_ADMIN_EMAIL=admin@africantradechamber.org
SEED_ADMIN_PASSWORD=ChangeMe-Atc-Dev-2026!

# Optional RBAC test users (used by npm run verify:rbac)
# SEED_EDITOR_EMAIL=editor@africantradechamber.org
# SEED_EDITOR_PASSWORD=ChangeMe-Editor-2026!

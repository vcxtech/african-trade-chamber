# Coolify environment variables (all required for AUTO_SEED deploys)
# Paste these into: Application → Environment Variables
# Replace placeholders — do NOT commit real passwords to git.

DATABASE_URI=postgresql://atc:YOUR_PASSWORD@atc-postgres:5432/atc_website
PAYLOAD_SECRET=generate-a-long-random-string-min-32-chars
NEXT_PUBLIC_SERVER_URL=http://your-app.sslip.io
# Same URL as above — set both so admin login cookies work after deploy
PAYLOAD_SERVER_URL=http://your-app.sslip.io
AUTO_SEED=true
# Required when AUTO_SEED=true — creates the first admin; deploy fails if missing
SEED_ADMIN_EMAIL=admin@africantradechamber.org
# Use letters and numbers only — avoid apostrophes/quotes (they break some env parsers)
SEED_ADMIN_PASSWORD=AtcAdmin2026Secure

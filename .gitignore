# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# local env files (never commit secrets)
.env
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.cursor/
.idea/
.vscode/
*.swp
*.swo

# Payload CMS uploads (local dev)
/media/*
!/media/.gitkeep
/form-attachments/*
!/form-attachments/.gitkeep

# WordPress media (~2GB) — see data/README.md for local setup
/data/uploads/
/public/uploads

# WordPress exports (large; may contain site content / emails)
/data/*.xml

# Keep data folder docs
!/data/
!/data/README.md

# Bundled WordPress plugins (reference only; not used by Next.js at runtime)
/plugins/

# Local legacy HTML snapshots (optional reference)
/reference-legacy/

# Ad-hoc temp files
.tmp-*
NUL
